main:
     mov rdi, 0x0A
     call :fib
     ret
fib:
     push rbx
     push rbp
     push r12
     mov rbp, rdi
     mov rbx, 0x02
     mov rcx, rbp
     cmp rcx, rbx
     setle cl
     movzx rcx, cl
     mov rax, 0x01
     test rcx, rcx
     jz :0
     jmp :1

000: mov rcx, rbp
     sub rcx, rax
     mov rdi, rcx
     call :fib
     mov r12, rax
     mov rax, rbp
     sub rax, rbx
     mov rdi, rax
     call :fib
     add r12, rax
     jmp :2

001: mov r12, rax
     jmp :2

002: mov rax, r12
     pop r12
     pop rbp
     pop rbx
     ret
