main:
     push rbx
     sub rsp, 0x08
     mov rax, 0x00
     lea rcx, [rsp]
     mov rbx, rcx
     mov rdx, rcx
     mov [rdx], rax
     mov rdi, rcx
     call :set
     mov rax, rbx
     mov rax, [rax]
     sub rsp, 0xFFFFFFFFFFFFFFF8
     pop rbx
     ret
set:
     mov rax, 0x01
     mov [rdi], rax
     mov rax, [rdi]
     ret
