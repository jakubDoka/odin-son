main:
     push rbx
     push rbp
     mov rcx, 0x0A
     mov rdx, 0x00
     mov rbx, 0x01
     mov rax, rbx
     mov rsi, rdx
     mov rbp, rcx
     jmp :0

000: mov rcx, rbp
     cmp rcx, rdx
     setz cl
     movzx rcx, cl
     test rcx, rcx
     jz :1
     jmp :2

001: mov rcx, rsi
     add rcx, rax
     sub rbp, rbx
     mov rsi, rax
     mov rax, rcx
     jmp :0

002: pop rbp
     pop rbx
     ret
