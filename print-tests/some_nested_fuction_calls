main:
     mov rdi, 0x01
     mov rsi, 0x02
     call :a
     ret
a:
     push rbx
     push rbp
     mov rax, rsi
     mov rbx, rax
     call :b
     mov rbp, rax
     mov rdi, rbx
     call :c
     mov rcx, rbp
     add rcx, rax
     mov rax, rcx
     pop rbp
     pop rbx
     ret
b:
     mov rax, rdi
     mov rcx, 0x02
     imul rax, rcx
     ret
c:
     mov rax, rdi
     mov rcx, 0x03
     imul rax, rcx
     ret
