main:
     push rbx
     mov rbx, 0x00
     mov rax, rbx
     jmp :0

000: mov rcx, 0x01
     add rbx, rcx
     mov rdx, 0x02
     cmp rdx, rbx
     setz dl
     movzx rdx, dl
     test rdx, rdx
     jz :1
     jmp :2

001: mov rdx, 0x03
     cmp rdx, rbx
     setz dl
     movzx rdx, dl
     test rdx, rdx
     jz :3
     jmp :4

003: mov rcx, 0x0A
     add rcx, rax
     mov rax, rcx
     jmp :0

004: jmp :5

005: add rax, rcx
     jmp :5

002: pop rbx
     ret
