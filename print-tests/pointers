main:
     push rcx
     push rbp
     mov rax, 0x00
     lea rcx, [rsp]
     mov rbp, rcx
     mov rdx, rcx
     mov [rdx], rax
     mov rdi, rcx
     call :set
     mov rax, rbp
     mov rax, [rax]
     pop rbp
     pop rcx
     ret
set:
     mov rax, 0x01
     mov [rdi], rax
     mov rax, [rdi]
     ret
